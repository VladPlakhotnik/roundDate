{
  "name": "rounddate",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "next dev --turbopack --port 6670",
    "build": "next build --turbopack",
    "start": "next start --port 6670",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "email:dev": "react-email dev --dir src/emails --port 6671",
    "resend:webhooks:create:local": "node scripts/resend-webhooks.mjs create:local",
    "resend:webhooks:create:prod": "node scripts/resend-webhooks.mjs create:prod",
    "resend:webhooks:list": "node scripts/resend-webhooks.mjs list"
  },
  "dependencies": {
