    "lucide-react": "^1.18.0",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.79.0",
    "recharts": "^3.8.1",
    "resend": "^6.12.4",
    "server-only": "^0.0.1",
